(function() {
    'use strict';
    const sleep = async (milliseconds) => {
        await new Promise(resolve => {
        return setTimeout(resolve, milliseconds)
        });
};

const addFinishButton = async () => {
    await sleep(3000);
    var elements = document.querySelectorAll("button.ng-hide.btn.btn-primary");
    elements[0].classList.value = 'btn btn-primary';
}

addFinishButton();

})();
